# ── Domain ──
DOMAIN=example.com

# ── Cloudflare ──
CLOUDFLARE_EMAIL=example@example.com
CLOUDFLARE_DNS_API_TOKEN=cfut_your_dns_api_token

# ── Grafana ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_please

# ── Arcane ──
ARCANE_ENCRYPTION_KEY=change_me_to_32_char_string
ARCANE_JWT_SECRET=change_me_to_random_string
