# ── Domain ──
DOMAIN=example.com

# ── PostgreSQL ──
POSTGRES_URL=postgresql+asyncpg://example_user:example_password@postgres:5432/example_db
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=example_db

# ── MongoDB ──
MONGODB_URL=mongodb://mongo_example_user:mongo_example_passwd@mongodb:27017
MONGO_INITDB_ROOT_USERNAME=mongo_example_user
MONGO_INITDB_ROOT_PASSWORD=mongo_example_passwd

# ── Sentry ──
SUNFLOWER_SENTRY_DSN=https://example.ingest.us.sentry.io/12345678
HELIOTROPE_SENTRY_DSN=https://example.ingest.us.sentry.io/12345678
