# ── Domain ──
DOMAIN=example.com

# ── PostgreSQL ──
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=example_db

# ── MongoDB Atlas ──
MONGODB_ATLAS_URL=mongodb+srv://example_user:example_password@localhost:27017/example_db

# ── Sentry ──
SUNFLOWER_SENTRY_DSN=https://example.ingest.us.sentry.io/12345678
HELIOTROPE_SENTRY_DSN=https://example.ingest.us.sentry.io/12345678
